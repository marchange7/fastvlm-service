[Unit]
Description=FastVLM Vision Service — Level 1+2
After=network.target

[Service]
User=crew
WorkingDirectory=/home/crew/git/fastvlm-service
ExecStart=/home/crew/.venv/nuclear/bin/uvicorn main:app --host 0.0.0.0 --port 8091
Restart=on-failure
RestartSec=5s
Environment=HF_HOME=/home/crew/.cache/huggingface

[Install]
WantedBy=multi-user.target
